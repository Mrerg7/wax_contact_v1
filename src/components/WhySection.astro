    <p class="mt-4 max-w-md mx-auto text-muted">A rare combination of universal relevance, modern branding, and deep cultural resonance.</p>
  </div>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
    <!-- Card 1 -->
    <div class="value-card bg-white border border-warm rounded-3xl p-8">
      <div class="w-12 h-12 bg-[#F8F1E9] rounded-2xl flex items-center justify-center mb-6">
