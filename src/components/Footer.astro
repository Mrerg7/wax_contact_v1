---
import { ACQUISITION_MAILTO, SITE } from '../config/site';
import AcquisitionCTA from './AcquisitionCTA.astro';
---

<footer id="acquire" class="relative border-t border-warm">
  <!-- Sophisticated domain acquisition CTA -->
  <div class="footer-cta-glow relative overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[#2D5A4A]/5 blur-[120px] rounded-full pointer-events-none"></div>

    <div class="relative max-w-screen-xl mx-auto px-6 py-20 md:py-28">
      <div class="bg-white border border-warm rounded-[2rem] p-8 md:p-14 text-center md:text-left shadow-lg shadow-[#2D5A4A]/5">
        <div class="grid md:grid-cols-12 gap-10 items-center">
          <div class="md:col-span-7 space-y-5">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#2D5A4A]/10 border border-[#2D5A4A]/20">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#2D5A4A] opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-[#2D5A4A]"></span>
              </span>
              <span class="text-xs font-bold uppercase tracking-[2px] text-forest">Available for Acquisition</span>
            </div>

            <h2 class="heading-serif text-3xl sm:text-5xl tracking-tight leading-tight text-dark">
              Acquire <span class="text-forest">{SITE.name}</span> — a rare global digital asset
            </h2>

            <p class="text-lg text-muted max-w-xl">
              For domain investors, salon groups, booking platforms, product brands, and visionary founders seeking a category-defining name at the intersection of professional beauty and universal recognition. Direct owner negotiation — no brokers.
            </p>

            <dl class="grid grid-cols-2 sm:grid-cols-4 gap-4 pt-2 text-left">
              <div>
                <dt class="text-[10px] uppercase tracking-widest text-[#8B8B8B] mb-1">Characters</dt>
                <dd class="heading-serif text-lg text-dark">11</dd>
              </div>
              <div>
                <dt class="text-[10px] uppercase tracking-widest text-[#8B8B8B] mb-1">TLD</dt>
                <dd class="heading-serif text-lg text-forest">.contact</dd>
              </div>
              <div>
                <dt class="text-[10px] uppercase tracking-widest text-[#8B8B8B] mb-1">Range</dt>
                <dd class="heading-serif text-lg text-dark">$35K–$65K</dd>
              </div>
              <div>
                <dt class="text-[10px] uppercase tracking-widest text-[#8B8B8B] mb-1">Transfer</dt>
                <dd class="heading-serif text-lg text-forest">Immediate</dd>
              </div>
            </dl>
          </div>

          <div class="md:col-span-5 flex flex-col items-center md:items-stretch gap-5">
            <div class="w-full p-6 rounded-2xl bg-[#F8F1E9] border border-warm text-center md:text-left">
              <div class="text-xs uppercase tracking-[2px] text-[#8B8B8B] mb-2 font-semibold">Acquisition Contact</div>
              <a
                href={ACQUISITION_MAILTO}
                class="text-xl sm:text-2xl heading-serif font-semibold text-forest hover:text-dark transition-colors break-all"
              >
                {SITE.email}
              </a>
              <p class="text-sm text-muted mt-3">Response within 24 hours. Escrow available.</p>
            </div>

            <AcquisitionCTA
              variant="forest"
              size="md"
              label="Inquire About Acquisition"
              class="w-full !rounded-2xl"
            />

            <p class="text-[11px] text-muted text-center md:text-left leading-relaxed">
              By contacting us, you acknowledge this is a demonstration listing. Terms subject to negotiation.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Legal disclaimer + meta footer -->
  <div class="max-w-screen-xl mx-auto px-6 pb-12">
    <div class="pt-10 border-t border-warm">
      <p class="text-xs text-muted leading-relaxed max-w-4xl mb-8">
        This website is for demonstration and informational purposes only. It does not constitute an offer of services,
        a commitment to deploy, or a guarantee of outcomes. All statistics, projections, and references to specific
        technologies are based on publicly available information as of {SITE.lastUpdated} and are subject to change.
      </p>

      <div class="flex flex-col md:flex-row gap-y-4 items-start md:items-center justify-between text-xs text-muted">
        <div>&copy; {new Date().getFullYear()} {SITE.name} — Premium Domain Available for Acquisition</div>
        <div class="flex flex-wrap gap-x-6 gap-y-2">
          <span>{SITE.location}</span>
          <span>Clean Title</span>
          <span>Ready for Immediate Transfer</span>
        </div>
        <a href={ACQUISITION_MAILTO} class="hover:text-forest transition-colors font-medium">
          {SITE.email}
        </a>
      </div>
    </div>
  </div>
</footer>
