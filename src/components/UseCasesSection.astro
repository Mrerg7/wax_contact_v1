<section id="use-cases" class="max-w-7xl mx-auto px-6 py-16 md:py-20">
  <div class="text-center mb-12">
    <div class="modern-pill mb-3">GLOBAL SCALE POTENTIAL</div>
    <h2 class="section-header tracking-tight">Built for worldwide ambition</h2>
    <p class="mt-3 max-w-md mx-auto text-muted">wax.contact is a rare global foundation that can support multiple high-value business models across borders.</p>
  </div>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
    <div class="use-case-card bg-white border border-warm rounded-3xl p-8">
      <div class="flex items-center gap-x-4 mb-5">
        <div class="text-forest">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M4.083 9h1.946c.089-1.546.383-2.97.837-4.118A6.004 6.004 0 004.083 9zM10 2a8 8 0 100 16 8 8 0 000-16zm0 2c-.076 0-.232.032-.465.262-.238.234-.497.623-.737 1.182-.389.907-.673 2.142-.766 3.556h3.936c-.093-1.414-.377-2.649-.766-3.556-.24-.56-.5-.948-.737-1.182C10.232 4.032 10.076 4 10 4zm3.971 5c-.089-1.546-.383-2.97-.837-4.118A6.004 6.004 0 0115.917 9h-1.946zm-2.003 2H8.032c.093 1.414.377 2.649.766 3.556.24.56.5.948.737 1.182.233.23.389.262.465.262.076 0 .232-.032.465-.262.238-.234.498-.623.737-1.182.389-.907.673-2.142.766-3.556zm1.166 4.118c.454-1.147.748-2.572.837-4.118h1.946a6.004 6.004 0 01-2.783 4.118zm-6.268 0C6.412 13.97 6.118 12.546 6.03 11H4.083a6.004 6.004 0 002.783 4.118z" clip-rule="evenodd" />
          </svg>
        </div>
        <h4 class="heading-serif text-lg">Global Booking Platform</h4>
      </div>
      <p class="text-muted">Become the trusted worldwide hub where clients connect with vetted professional estheticians and salons across continents.</p>
    </div>

    <div class="use-case-card bg-white border border-warm rounded-3xl p-8">
      <div class="flex items-center gap-x-4 mb-5">
        <div class="text-forest">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z" />
          </svg>
        </div>
        <h4 class="heading-serif text-lg">International Salon Group or Franchise</h4>
      </div>
      <p class="text-muted">Launch or scale a premium waxing brand with instant global recognition and a name that travels effortlessly across markets.</p>
    </div>

    <div class="use-case-card bg-white border border-warm rounded-3xl p-8">
      <div class="flex items-center gap-x-4 mb-5">
        <div class="text-forest">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M7 2a2 2 0 00-2 2v12a2 2 0 002 2h6a2 2 0 002-2V4a2 2 0 00-2-2H7zm3 14a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
          </svg>
        </div>
        <h4 class="heading-serif text-lg">Mobile / On-Demand Global Service</h4>
      </div>
      <p class="text-muted">Perfect for a high-end mobile or concierge waxing concept that can expand city-by-city or country-by-country under one powerful name.</p>
    </div>

    <div class="use-case-card bg-white border border-warm rounded-3xl p-8">
      <div class="flex items-center gap-x-4 mb-5">
        <div class="text-forest">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z" />
          </svg>
        </div>
        <h4 class="heading-serif text-lg">International Training Academy</h4>
      </div>
      <p class="text-muted">Position as the global authority for professional waxing education, certification, and standards with a name that commands respect worldwide.</p>
    </div>

    <div class="use-case-card bg-white border border-warm rounded-3xl p-8">
      <div class="flex items-center gap-x-4 mb-5">
        <div class="text-forest">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M11 3a1 1 0 10-2 0v1a1 1 0 102 0V3zM15.657 5.757a1 1 0 00-1.414-1.414l-.707.707a1 1 0 001.414 1.414l.707-.707zM18 10a1 1 0 01-1 1h-1a1 1 0 110-2h1a1 1 0 011 1zM5.05 6.464A1 1 0 106.464 5.05l-.707-.707a1 1 0 00-1.414 1.414l.707.707zM5 10a1 1 0 01-1 1H3a1 1 0 110-2h1a1 1 0 011 1zM8 16v-1h4v1a2 2 0 11-4 0zM12 14c.015-.34.208-.646.477-.653a6.985 6.985 0 002.365-.848L16.244 14.9a1 1 0 101.414-1.414L16 11.887a6.993 6.993 0 00-2-3.436V7a1 1 0 00-1-1H7a1 1 0 00-1 1v1.451a6.993 6.993 0 00-2 3.436L2.343 11.9a1 1 0 101.414 1.414l1.402-1.402a6.985 6.985 0 002.365.848C7.792 12.354 7.985 12.66 8 13h4z" />
          </svg>
        </div>
        <h4 class="heading-serif text-lg">Premium Global Product Brand</h4>
      </div>
      <p class="text-muted">Launch a signature line of professional waxes, aftercare, tools, and devices under a clean, ownable name that works in every market.</p>
    </div>

    <div class="use-case-card bg-white border border-warm rounded-3xl p-8">
      <div class="flex items-center gap-x-4 mb-5">
        <div class="text-forest">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M2 5a2 2 0 012-2h8a2 2 0 012 2v10a2 2 0 002 2H4a2 2 0 01-2-2V5zm3 1h6v4H5V6zm6 6H5v2h6v-2z" clip-rule="evenodd" />
            <path d="M15 7h1a2 2 0 012 2v5.5a1.5 1.5 0 01-3 0V7z" />
          </svg>
        </div>
        <h4 class="heading-serif text-lg">Media, Education &amp; Community</h4>
      </div>
      <p class="text-muted">Build the leading global resource, magazine, podcast, or community around professional hair removal, grooming, and self-care.</p>
    </div>
  </div>
</section>
